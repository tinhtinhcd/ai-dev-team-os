# Slack → Linear integration (Van Bot)
# Create a Slack app at https://api.slack.com/apps and enable Events API + app_mention

# From Slack app: Basic Information → App Credentials
SLACK_SIGNING_SECRET=

# From Slack app: OAuth & Permissions → Bot User OAuth Token (starts with xoxb-)
SLACK_BOT_TOKEN=

# Your Slack workspace URL (e.g. https://vanaiworkspace.slack.com)
SLACK_WORKSPACE_URL=https://vanaiworkspace.slack.com

# Linear API key (from https://linear.app/settings/api)
LINEAR_API_KEY=

# Linear team ID (from team URL or GraphQL teams query)
LINEAR_TEAM_ID=

# Linear user ID for Cursor assignee (optional; from user profile "Copy model UUID")
LINEAR_CURSOR_USER_ID=

# Linear webhook integration
LINEAR_WEBHOOK_SECRET=     # From Linear webhook config (recommended for production)
SLACK_BOT_TOKEN=           # Bot token with chat:write scope
SLACK_CHANNEL_ID=          # Default Slack channel (e.g. C0ABQLYUE0K)
LINEAR_THREAD_MAP_PATH=    # Optional: path to linear-thread-map.json

# Slack → Linear (Van Bot) — create issues from @mentions
SLACK_SIGNING_SECRET=      # From Slack app: Basic Information → App Credentials
SLACK_WORKSPACE_URL=       # e.g. https://vanaiworkspace.slack.com
LINEAR_API_KEY=            # From https://linear.app/settings/api
LINEAR_TEAM_ID=            # From team URL or GraphQL teams query
LINEAR_CURSOR_USER_ID=     # Optional: for auto-assign to Cursor

# Slack reporting (TIN-11) — agent status updates via /api/report
SLACK_CHANNEL=             # Channel ID or name for reports (e.g. C0ABQLYUE0K)

# Open tickets sync (npm run sync:open-tickets) — fetches from Linear to docs/OPEN_TICKETS.md
# LINEAR_API_KEY=           # Required for sync script
# LINEAR_TEAM_ID=           # Optional: filter to specific team
